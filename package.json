{
  "name": "core-docker",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.js",
    "test:e2e:only": "E2E_SKIP_PROVISION=1 E2E_SKIP_TEARDOWN=1 vitest run --config vitest.e2e.config.js",
    "test:e2e:setup": "sudo bash vm/setup-cluster.sh --recreate",
    "test:e2e:teardown": "sudo bash vm/destroy-cluster.sh",
    "test:e2e:full": "npm run test:e2e:setup && npm run test:e2e && npm run test:e2e:teardown",
    "backend:start": "npm run start -w backend",
    "backend:dev": "npm run dev -w backend",
    "frontend:dev": "npm run dev -w frontend",
    "frontend:build": "npm run build -w frontend",
    "frontend:start": "npm run start -w frontend"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "vitest": "^4.1.9"
  },
  "type": "module"
}
